# Репозиторий GitHub (owner/repo) — используется для pull образов из ghcr.io
GITHUB_REPOSITORY=owner/athletica-crm

# Домен production-сервера
DOMAIN=yourdomain.com

# PostgreSQL
POSTGRES_USER=athletica
POSTGRES_PASSWORD=CHANGE_ME

# Metabase — сгенерировать: openssl rand -hex 32
METABASE_DB_PASSWORD=CHANGE_ME
METABASE_READER_PASSWORD=CHANGE_ME

# JWT — случайная строка от 64 символов, например: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# MinIO (S3-совместимое хранилище)
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=athletica-crm

# SMTP (исходящая почта)
SMTP_HOST=smtp.example.com
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_ADDRESS=noreply@yourdomain.com
